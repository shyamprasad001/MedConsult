# ============================================================
#  Book-A-Doctor — Frontend Environment Variables Template
#
#  Instructions:
#    1. Copy this file to `.env`  (cp .env.example .env)
#    2. Fill in your actual values below
#    3. NEVER commit the .env file to version control
#
#  Note: All REACT_APP_ variables are embedded in the build
#  at compile time. Restart the dev server after changes.
# ============================================================

# Backend API base URL — must match your running backend server
# Development: http://localhost:5000/api/v1
# Production:  https://your-api-domain.com/api/v1
# Do NOT add a trailing slash.
REACT_APP_API_URL=http://localhost:5000/api/v1

# Google OAuth Client ID
# This MUST match the GOOGLE_CLIENT_ID in your backend .env
# Obtain from: https://console.cloud.google.com/
#   1. Go to APIs & Services → Credentials
#   2. Create OAuth 2.0 Client ID (Web application type)
#   3. Add http://localhost:3000 to Authorized JavaScript origins
#   4. Copy the Client ID here
REACT_APP_GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
