# ============================================================
#  Book-A-Doctor — Backend Environment Variables Template
#
#  Instructions:
#    1. Copy this file to `.env`  (cp .env.example .env)
#    2. Fill in your actual values below
#    3. NEVER commit the .env file to version control
# ============================================================

# --- Server ---
# Options: development | production | test
NODE_ENV=development

# Port the Express server will listen on
PORT=5000

# --- MongoDB ---
# Local MongoDB:  mongodb://localhost:27017/book_a_doctor
# MongoDB Atlas:  mongodb+srv://<user>:<password>@cluster.mongodb.net/book_a_doctor?retryWrites=true&w=majority
MONGO_URI=mongodb://localhost:27017/book_a_doctor

# --- JWT ---
# Generate a strong secret:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Keep this secret and never share it!
JWT_SECRET=your-very-long-random-secret-key-at-least-64-characters

# Token expiry time (e.g., 7d, 24h, 30m)
JWT_EXPIRES_IN=7d

# --- CORS ---
# The origin of your frontend application.
# For production, set this to your actual domain: https://yourdomain.com
# Multiple origins can be separated by commas: http://localhost:3000,https://yourdomain.com
CLIENT_ORIGIN=http://localhost:3000

# --- File Uploads (Multer) ---
# Directory name relative to the backend root where uploads are stored
UPLOAD_DIR=uploads

# Maximum file size allowed for uploads (in MB)
MAX_FILE_SIZE_MB=5

# --- SMTP Mailer Settings ---
# For Gmail, use smtp.gmail.com with port 587
# You'll need to generate a Gmail App Password:
#   1. Enable 2-Factor Authentication on your Google account
#   2. Go to: https://myaccount.google.com/apppasswords
#   3. Generate a new App Password for "Mail"
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password

# Note: If SMTP credentials are not provided, the app uses Ethereal
# (https://ethereal.email) as a fallback in development mode.
# Email preview URLs will be printed to the console.

# --- Google OAuth Settings ---
# Create credentials at: https://console.cloud.google.com/
#   1. Create a new project (or use an existing one)
#   2. Enable the Google+ API
#   3. Create OAuth 2.0 credentials (Web application type)
#   4. Add http://localhost:3000 to Authorized JavaScript origins
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
